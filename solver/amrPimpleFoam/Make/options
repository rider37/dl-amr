EXE_INC = \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/sampling/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/turbulenceModels/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/incompressible/lnInclude \
    -I$(LIB_SRC)/transportModels \
    -I$(LIB_SRC)/transportModels/incompressible/singlePhaseTransportModel \
    -I$(LIB_SRC)/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/regionFaModels/lnInclude \
    -I/usr/local/libtorch/include \
    -I/usr/local/libtorch/include/torch/csrc/api/include \
    -D_GLIBCXX_USE_CXX11_ABI=1 \
    -std=c++17 \
    -fopenmp

EXE_LIBS = \
    -lfiniteVolume \
    -lfvOptions \
    -lmeshTools \
    -lsampling \
    -lturbulenceModels \
    -lincompressibleTurbulenceModels \
    -lincompressibleTransportModels \
    -ldynamicMesh \
    -ldynamicFvMesh \
    -ltopoChangerFvMesh \
    -latmosphericModels \
    -lregionFaModels \
    -lfiniteArea \
    -Wl,-rpath,/usr/local/libtorch/lib /usr/local/libtorch/lib/libtorch.so /usr/local/libtorch/lib/libc10.so \
    -Wl,--no-as-needed,/usr/local/libtorch/lib/libtorch_cpu.so \
    -Wl,--as-needed /usr/local/libtorch/lib/libc10.so \
    -Wl,--no-as-needed,/usr/local/libtorch/lib/libtorch.so \
    -fopenmp
