    format      ascii;
    class       dictionary;
    location    "constant";
    object      dynamicMeshDict;
}

dynamicFvMesh   dynamicRefineFvMesh;

dynamicRefineFvMeshCoeffs
{
    refineInterval  10;

    field           refineFlag;

    lowerRefineLevel 0.9;
    upperRefineLevel 1.1;

    unrefineLevel   0.8;

