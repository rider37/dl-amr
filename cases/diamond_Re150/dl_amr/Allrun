#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

# Verify pretrained model is present (downloaded via 'make download-models')
if [ ! -f constant/model.ts ]; then
    echo "ERROR: constant/model.ts not found."
    echo "Either run 'make download-models' from the repo root, or symlink:"
    echo "  ln -sf \$(pwd)/../../../ml/pretrained/heteroscedastic_unet.pt constant/model.ts"
    exit 1
fi

blockMesh > log.blockMesh 2>&1
checkMesh > log.checkMesh 2>&1

if [ -x /usr/bin/time ]; then
    export TORCH_CUDNN_V8_API_DISABLED=1
    /usr/bin/time -v amrPimpleFoam > log.pimpleFoam 2> log.time
else
    export TORCH_CUDNN_V8_API_DISABLED=1
    amrPimpleFoam > log.pimpleFoam 2>&1
fi
